generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ===== NGƯỜI DÙNG & PHÂN QUYỀN =====
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  fullName  String
  phone     String?
  email     String?
  role      Role     @default(STAFF_SALES)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())

  invoices  Invoice[]
  wasteLogs WasteLog[]
  batches   Batch[]

  @@map("users")
}

enum Role {
  MANAGER
  STAFF_SALES
  STAFF_WAREHOUSE
}

enum Status {
  ACTIVE
  INACTIVE
}

// ===== DANH MỤC TRÁI CÂY =====
model Product {
  id             String        @id @default(cuid())
  name           String        @unique
  unit           String        // kg, thùng, khay
  evaporationRate Float        // % hao hụt/ngày
  shelfLifeDays  Int           // số ngày tươi
  category       String?       // nhập khẩu, nội địa
  status         ProductStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())

  batches        Batch[]
  invoiceItems   InvoiceItem[]

  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
}

// ===== NHÀ CUNG CẤP =====
model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?  @unique
  phone       String   @unique
  address     String?
  createdAt   DateTime @default(now())

  batches     Batch[]

  @@map("suppliers")
}

// ===== LÔ HÀNG NHẬP KHO =====
model Batch {
  id            String      @id @default(cuid())
  batchCode     String      @unique // L-20260514-001
  product       Product     @relation(fields: [productId], references: [id])
  productId     String
  supplier      Supplier    @relation(fields: [supplierId], references: [id])
  supplierId    String
  quantity      Float       // số lượng nhập
  remaining     Float       // tồn thực tế (sau hao hụt)
  importPrice   Float       // giá nhập
  packagedAt    DateTime    // ngày đóng gói
  expiredAt     DateTime    // HSD = packagedAt + shelfLifeDays
  status        BatchStatus @default(FRESH)
  createdAt     DateTime    @default(now())
  createdBy     User        @relation(fields: [createdById], references: [id])
  createdById   String

  invoiceItems  InvoiceItem[]
  wasteLogs     WasteLog[]

  @@map("batches")
}

enum BatchStatus {
  FRESH        // tươi
  NEAR_EXPIRY  // cần bán gấp (còn < 2 ngày)
  EXPIRED      // hết hạn
  DISPOSED     // đã hủy
}

// ===== KHÁCH HÀNG =====
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  address   String?
  points    Int      @default(0) // điểm tích lũy
  createdAt DateTime @default(now())

  invoices  Invoice[]

  @@map("customers")
}

// ===== HÓA ĐƠN BÁN HÀNG =====
model Invoice {
  id            String        @id @default(cuid())
  invoiceCode   String        @unique
  customer      Customer?     @relation(fields: [customerId], references: [id])
  customerId    String?
  totalAmount   Float
  discount      Float         @default(0)
  finalAmount   Float
  paymentMethod PaymentMethod @default(CASH)
  channel       SaleChannel   @default(POS)
  status        InvoiceStatus @default(PENDING)
  createdAt     DateTime      @default(now())
  createdBy     User          @relation(fields: [createdById], references: [id])
  createdById   String

  items         InvoiceItem[]

  @@map("invoices")
}

enum PaymentMethod {
  CASH
  QR
  CARD
}

enum SaleChannel {
  POS
  ONLINE
}

enum InvoiceStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

// ===== CHI TIẾT HÓA ĐƠN =====
model InvoiceItem {
  id         String  @id @default(cuid())
  invoice    Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId  String
  product    Product @relation(fields: [productId], references: [id])
  productId  String
  batch      Batch   @relation(fields: [batchId], references: [id])
  batchId    String
  quantity   Float
  unitPrice  Float
  subtotal   Float

  @@map("invoice_items")
}

// ===== PHIẾU HỦY/XẢ HÀNG =====
model WasteLog {
  id          String      @id @default(cuid())
  batch       Batch       @relation(fields: [batchId], references: [id])
  batchId     String
  quantity    Float
  reason      WasteReason
  note        String?
  createdAt   DateTime    @default(now())
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdById String

  @@map("waste_logs")
}

enum WasteReason {
  EXPIRED
  DAMAGED
  BIOLOGICAL
  OTHER
}