generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. NGƯỜI DÙNG & PHÂN QUYỀN NỘI BỘ
// ==========================================
model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  fullName  String
  phone     String?
  email     String?
  role      Role       @default(STAFF_SALES)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  invoices       Invoice[]       // Đơn hàng xuất bán
  wasteLogs      WasteLog[]      // Phiếu hủy hàng
  importReceipts ImportReceipt[] // Phiếu nhập kho đã duyệt
  batches        Batch[]         // Phụ trách trực tiếp đóng gói lô

  @@map("users")
}

enum Role {
  MANAGER
  STAFF_SALES
  STAFF_WAREHOUSE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

// ==========================================
// 2. DANH MỤC & SẢN PHẨM (Tích hợp E-Commerce)
// ==========================================
model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?   @db.Text
  createdAt   DateTime  @default(now())

  products    Product[]

  @@map("categories")
}

model Product {
  id              String        @id @default(cuid())
  sku             String        @unique // Mã vạch chuẩn POS
  name            String        @unique
  description     String?       @db.Text // Bài viết cho Web
  imageUrl        String?       // Ảnh cho Web
  unit            String        // kg, hộp, khay...
  currentPrice    Float         // Giá bán lẻ hiện tại
  evaporationRate Float         // % hao hụt/ngày tự nhiên
  shelfLifeDays   Int           // Số ngày tươi
  
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batches         Batch[]
  invoiceItems    InvoiceItem[]

  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
}

// ==========================================
// 3. NHÀ CUNG CẤP & NHẬP KHO (Chuẩn Kế Toán ERP)
// ==========================================
model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?  @unique
  phone       String   @unique
  address     String?
  createdAt   DateTime @default(now())

  importReceipts ImportReceipt[]

  @@map("suppliers")
}

model ImportReceipt {
  id           String   @id @default(cuid())
  receiptCode  String   @unique // Mã phiếu nhập (Vd: PN-2605-001)
  
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  
  totalAmount  Float    // Tổng tiền công nợ với nhà cung cấp
  note         String?  @db.Text
  
  receivedById String
  receivedBy   User     @relation(fields: [receivedById], references: [id])
  
  createdAt    DateTime @default(now())

  batches      Batch[]  // 1 Phiếu nhập sẽ bao gồm nhiều Lô hàng (Batches)

  @@map("import_receipts")
}

// ==========================================
// 4. LÔ HÀNG (Core Logic - FIFO)
// ==========================================
model Batch {
  id              String        @id @default(cuid())
  batchCode       String        @unique // QR Code dán lên thùng
  
  importReceiptId String
  importReceipt   ImportReceipt @relation(fields: [importReceiptId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  
  quantity        Float         // Số lượng nhập
  remaining       Float         // Tồn kho thực tế
  importPrice     Float         // Giá vốn nhập vào
  
  packagedAt      DateTime      // Ngày đóng gói
  expiredAt       DateTime      // HSD = packagedAt + shelfLifeDays
  status          BatchStatus   @default(FRESH)
  
  createdAt       DateTime      @default(now())
  createdBy       User          @relation(fields: [createdById], references: [id])
  createdById     String

  invoiceItems    InvoiceItem[]
  wasteLogs       WasteLog[]

  @@map("batches")
}

enum BatchStatus {
  FRESH        // Tươi mới
  NEAR_EXPIRY  // Cận date (khuyến mãi)
  EXPIRED      // Hết hạn
  DISPOSED     // Đã tiêu hủy
}

// ==========================================
// 5. KHÁCH HÀNG (CRM)
// ==========================================
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique // Email login Web
  password  String?          // Pass login Web
  address   String?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  invoices  Invoice[]

  @@map("customers")
}

// ==========================================
// 6. HÓA ĐƠN & GIAO DỊCH (Đa kênh - Omnichannel)
// ==========================================
model Invoice {
  id              String        @id @default(cuid())
  invoiceCode     String        @unique // Vd: INV-2605-001
  
  customer        Customer?     @relation(fields: [customerId], references: [id])
  customerId      String?
  
  totalAmount     Float
  discount        Float         @default(0)
  shippingFee     Float         @default(0) // Phí ship Online
  finalAmount     Float
  
  paymentMethod   PaymentMethod @default(CASH)
  channel         SaleChannel   @default(POS)
  status          InvoiceStatus @default(PENDING)
  
  shippingAddress String?       @db.Text
  trackingCode    String?       // Mã vận đơn GHTK/Viettel
  
  createdAt       DateTime      @default(now())
  createdBy       User?         @relation(fields: [createdById], references: [id])
  createdById     String?       // Khách tự đặt Online sẽ là Null

  items           InvoiceItem[]

  @@map("invoices")
}

enum PaymentMethod {
  CASH
  QR
  CARD
  COD
  BANK_TRANSFER
}

enum SaleChannel {
  POS
  ONLINE
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  SHIPPING
  PAID
  DELIVERED
  CANCELLED
}

// ==========================================
// 7. CHI TIẾT HÓA ĐƠN
// ==========================================
model InvoiceItem {
  id        String  @id @default(cuid())
  
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String
  
  product   Product @relation(fields: [productId], references: [id])
  productId String
  
  batch     Batch   @relation(fields: [batchId], references: [id])
  batchId   String
  
  quantity  Float
  unitPrice Float   // Giá chốt tại thời điểm mua
  subtotal  Float

  @@map("invoice_items")
}

// ==========================================
// 8. LOG HAO HỤT & HỦY HÀNG
// ==========================================
model WasteLog {
  id          String      @id @default(cuid())
  
  batch       Batch       @relation(fields: [batchId], references: [id])
  batchId     String
  
  quantity    Float
  reason      WasteReason
  note        String?     @db.Text
  
  createdAt   DateTime    @default(now())
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdById String

  @@map("waste_logs")
}

enum WasteReason {
  EXPIRED     // Hết hạn
  DAMAGED     // Hư hỏng/Bầm dập
  BIOLOGICAL  // Hao hụt sinh học (bay hơi nước)
  PROMOTION   // Cắt làm Sampling (Dùng thử)
  OTHER
}