generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// 1. NGƯỜI DÙNG & PHÂN QUYỀN NỘI BỘ
// ==========================================
model User {
  id        String     @id @default(cuid())
  username  String     @unique
  password  String
  fullName  String
  phone     String?
  email     String?
  role      Role       @default(STAFF_SALES)
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())

  invoices         Invoice[]         // Đơn hàng xuất bán
  wasteLogs        WasteLog[]        // Phiếu hủy hàng
  importReceipts   ImportReceipt[]   // Phiếu nhập kho đã duyệt
  batches          Batch[]           // Phụ trách trực tiếp đóng gói lô
  sessions         Session[]         // Quản lý đăng nhập
  stockAdjustments StockAdjustment[] // Lịch sử điều chỉnh tồn kho
  workShifts       WorkShift[]       // 🌟 SỬA LỖI: Thêm quan hệ ngược cho Ca làm việc
  auditLogs        AuditLog[]        // 🌟 SỬA LỖI: Thêm quan hệ ngược cho Nhật ký hệ thống

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("sessions")
}

enum Role {
  MANAGER
  STAFF_SALES
  STAFF_WAREHOUSE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

// ==========================================
// 2. DANH MỤC & SẢN PHẨM (Tích hợp E-Commerce)
// ==========================================
model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?  @db.Text
  createdAt   DateTime @default(now())

  products Product[]

  @@map("categories")
}

model Product {
  id              String        @id @default(cuid())
  sku             String        @unique // Mã vạch chuẩn POS
  name            String        @unique
  description     String?       @db.Text // Bài viết cho Web
  imageUrl        String?       // Ảnh cho Web
  unit            String        // kg, hộp, khay...
  currentPrice    Float         // Giá bán lẻ hiện tại
  evaporationRate Float         // % hao hụt/ngày tự nhiên
  shelfLifeDays   Int           // Số ngày tươi
  
  categoryId      String
  category        Category      @relation(fields: [categoryId], references: [id])
  
  status          ProductStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  batches      Batch[]
  invoiceItems InvoiceItem[]
  promotions   Promotion[]   // Khuyến mãi áp dụng riêng cho sản phẩm

  @@map("products")
}

enum ProductStatus {
  ACTIVE
  DISCONTINUED
}

// ==========================================
// 3. NHÀ CUNG CẤP & NHẬP KHO (Chuẩn Kế Toán ERP)
// ==========================================
model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?
  email       String?  @unique
  phone       String   @unique
  address     String?
  createdAt   DateTime @default(now())

  importReceipts ImportReceipt[]

  @@map("suppliers")
}

model ImportReceipt {
  id          String   @id @default(cuid())
  receiptCode String   @unique // Mã phiếu nhập (Vd: PN-2605-001)
  
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  totalAmount Float    // Tổng tiền công nợ với nhà cung cấp
  note        String?  @db.Text
  
  receivedById String
  receivedBy   User     @relation(fields: [receivedById], references: [id])
  
  createdAt   DateTime @default(now())

  batches Batch[] // 1 Phiếu nhập sẽ bao gồm nhiều Lô hàng (Batches)

  @@map("import_receipts")
}

// ==========================================
// 4. LÔ HÀNG (Core Logic - FIFO & Hao hụt)
// ==========================================
model Batch {
  id                 String        @id @default(cuid())
  batchCode          String        @unique // QR Code dán lên thùng
  
  importReceiptId    String
  importReceipt      ImportReceipt @relation(fields: [importReceiptId], references: [id], onDelete: Cascade)
  
  productId          String
  product            Product       @relation(fields: [productId], references: [id])
  
  quantity           Float         // Số lượng nhập ban đầu
  remaining          Float         // Tồn kho trên sổ sách
  effectiveRemaining Float         // Tồn kho thực tế
  importPrice        Float         // Giá vốn nhập vào
  
  packagedAt         DateTime      // Ngày đóng gói
  expiredAt          DateTime      // HSD = packagedAt + shelfLifeDays
  status             BatchStatus   @default(FRESH)
  
  createdAt          DateTime      @default(now())
  createdById        String
  createdBy          User          @relation(fields: [createdById], references: [id])

  invoiceItems     InvoiceItem[]
  wasteLogs        WasteLog[]
  stockAdjustments StockAdjustment[]

  @@index([status])
  @@index([expiredAt])
  @@index([productId])
  @@map("batches")
}

enum BatchStatus {
  FRESH        // Tươi mới
  NEAR_EXPIRY  // Cận date (khuyến mãi)
  EXPIRED      // Hết hạn
  DISPOSED     // Đã tiêu hủy
}

// ==========================================
// 5. ĐIỀU CHỈNH KHO (Kiểm kê thực tế)
// ==========================================
model StockAdjustment {
  id          String   @id @default(cuid())
  
  batchId     String
  batch       Batch    @relation(fields: [batchId], references: [id])
  
  before      Float    // Số lượng trước kiểm kê
  after       Float    // Số lượng thực tế sau kiểm kê
  delta       Float    // Độ chênh lệch (after - before)
  reason      String   // Lý do lệch (Ví dụ: "Khách trộm", "Cân sai")
  
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@map("stock_adjustments")
}

// ==========================================
// 6. KHÁCH HÀNG & TÍCH ĐIỂM (CRM)
// ==========================================
model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  email     String?  @unique // Email login Web
  password  String?           // Pass login Web
  address   String?
  points    Int      @default(0)
  createdAt DateTime @default(now())

  invoices          Invoice[]
  pointTransactions PointTransaction[]

  @@map("customers")
}

model PointTransaction {
  id          String   @id @default(cuid())
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  delta       Int      // +điểm tích, -điểm tiêu
  reason      String   // Mô tả: "Mua hàng INV-001", "Đổi quà"
  
  invoiceId   String?
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  
  createdAt   DateTime @default(now())

  @@map("point_transactions")
}

// ==========================================
// 7. KHUYẾN MÃI & CHIẾT KHẤU
// ==========================================
model Promotion {
  id              String       @id @default(cuid())
  name            String       // Tên chương trình (VD: "Xả hàng dâu tây cận date")
  description     String?      @db.Text
  discountPercent Float        // % Giảm giá
  
  productId       String?      // Áp dụng cho 1 sản phẩm cụ thể (Null = áp dụng tất cả)
  product         Product?     @relation(fields: [productId], references: [id])
  
  applyToStatus   BatchStatus? // VD: Chỉ giảm giá nếu lô hàng có trạng thái NEAR_EXPIRY
  
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())

  invoiceItems    InvoiceItem[] // 🌟 SỬA LỖI: Thêm quan hệ ngược cho Chi tiết hóa đơn áp dụng KM

  @@map("promotions")
}

// ==========================================
// 8. HÓA ĐƠN & GIAO DỊCH (Đa kênh - Omnichannel)
// ==========================================
model Invoice {
  id              String        @id @default(cuid())
  invoiceCode     String        @unique // Vd: INV-2605-001
  
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  
  totalAmount     Float         // Tổng tiền gốc
  discountPercent Float         @default(0) // % Giảm giá áp dụng
  discount        Float         @default(0) // Số tiền giảm giá
  pointsUsed      Int           @default(0) // Số điểm khách đã tiêu cho đơn này
  shippingFee     Float         @default(0) // Phí ship Online
  finalAmount     Float         // Tiền khách phải trả cuối cùng
  
  paymentMethod   PaymentMethod @default(CASH)
  channel         SaleChannel   @default(POS)
  status          InvoiceStatus @default(PENDING)
  
  shippingAddress String?       @db.Text
  trackingCode    String?       // Mã vận đơn GHTK/Viettel
  
  createdAt       DateTime      @default(now())
  createdById     String?       // Khách tự đặt Online sẽ là Null
  createdBy       User?         @relation(fields: [createdById], references: [id])

  items             InvoiceItem[]
  pointTransactions PointTransaction[]

  @@index([createdAt])
  @@index([status])
  @@map("invoices")
}

enum PaymentMethod {
  CASH
  QR
  CARD
  COD
  BANK_TRANSFER
}

enum SaleChannel {
  POS
  ONLINE
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  SHIPPING
  PAID
  DELIVERED
  CANCELLED
}

// ==========================================
// 9. CHI TIẾT HÓA ĐƠN
// ==========================================
model InvoiceItem {
  id             String     @id @default(cuid())
  
  invoiceId      String
  invoice        Invoice    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  
  productId      String
  product        Product    @relation(fields: [productId], references: [id])
  
  batchId        String
  batch          Batch      @relation(fields: [batchId], references: [id])
  discountAmount Float      @default(0) // Số tiền được giảm riêng cho mặt hàng này
  promotionId    String?
  promotion      Promotion? @relation(fields: [promotionId], references: [id])
  quantity       Float
  unitPrice      Float      // Giá chốt tại thời điểm mua
  subtotal       Float

  @@map("invoice_items")
}

// ==========================================
// 10. LOG HAO HỤT & HỦY HÀNG
// ==========================================
model WasteLog {
  id          String      @id @default(cuid())
  
  batchId     String
  batch       Batch       @relation(fields: [batchId], references: [id])
  
  quantity    Float
  reason      WasteReason
  note        String?     @db.Text
  
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  @@map("waste_logs")
}

enum WasteReason {
  EXPIRED      // Hết hạn
  DAMAGED      // Hư hỏng/Bầm dập
  BIOLOGICAL   // Hao hụt sinh học (bay hơi nước)
  PROMOTION    // Cắt làm Sampling (Dùng thử)
  OTHER
}

// ==========================================
// 11. LỊCH LÀM VIỆC NỘI BỘ
// ==========================================
model WorkShift {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  date      DateTime    @db.Date // Ngày làm việc
  shiftType ShiftType   // SÁNG, CHIỀU, TỐI
  status    ShiftStatus @default(SCHEDULED)
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([userId, date, shiftType])
  @@map("work_shifts")
}

enum ShiftType {
  MORNING   // 06:00 - 14:00
  AFTERNOON // 14:00 - 22:00
  EVENING   // 22:00 - 06:00
}

enum ShiftStatus {
  SCHEDULED // Đã đăng ký
  COMPLETED // Đã hoàn thành
  ABSENT    // Vắng mặt
}

// ==========================================
// 12. NHẬT KÝ HỆ THỐNG (AUDIT LOGS)
// ==========================================
model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String   // Ví dụ: "UPDATE_PRICE", "DEACTIVATE_USER"
  target    String   // Tên bảng hoặc đối tượng bị tác động (Ví dụ: "Product", "User")
  targetId  String   // ID của đối tượng bị tác động
  oldValue  String?  @db.Text // Giá trị cũ (JSON string) nếu cần
  newValue  String?  @db.Text // Giá trị mới (JSON string) nếu cần
  createdAt DateTime @default(now())

  @@map("audit_logs")
}
